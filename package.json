{
  "name": "mindtrace-for-playwright",
  "version": "1.0.0",
  "description": "## 🧠 AI-Governed Test Automation with Self-Healing",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "contracts:validate": "node contracts/scripts/validate-contracts.mjs",
    "bootstrap": "./scripts/bootstrap.sh",
    "mindtrace:build": "cd mindtrace-ai-runtime && npm run build",
    "mindtrace:run": "node mindtrace-ai-runtime/dist/cli.js run",
    "mindtrace:ci": "npm run contracts:validate && npm run mindtrace:build && node mindtrace-ai-runtime/dist/cli.js run --run-name ci-${CI_BUILD_ID:-${GITHUB_RUN_ID:-local}} --allow-overwrite"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
