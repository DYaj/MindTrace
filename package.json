{
  "name": "mindtrace-for-playwright",
  "private": true,
  "workspaces": [
    "shared-packages/*",
    "governance-mcp",
    "frameworks-mcp",
    "orchestrator-mcp",
    "mindtrace-ai-runtime",
    "repo-intelligence-mcp",
    "ui-server",
    "ui-client"
  ],
  "scripts": {
    "build:ui-types": "npm -w @breakline/ui-types run build",
    "build:ui-server": "npm -w ui-server run build",
