{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Patch Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "actions"],
  "properties": {
    "plan_id": { "type": "string" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "reason"],
        "properties": {
          "type": { "type": "string" },
          "reason": { "type": "string" },
          "confidence": { "type": "number" }
        }
      }
    }
  }
}
