{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Root Cause Summary",
  "description": "MindTrace RCA - Failure classification results",
  "type": "object",
  "required": ["category", "confidence", "isFlaky"],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["dom_changed", "selector_failed", "api_error", "timeout", "flaky", "navigation_mismatch", "ux_regression", "environmental", "test_logic_error", "none"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "isFlaky": {
      "type": "boolean"
    },
    "reasoning": {
      "type": "string"
    },
    "suggestedActions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "affectedTests": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
