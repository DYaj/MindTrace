{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Healed Selectors",
  "description": "MindTrace Heal - Selector repair results",
  "type": "object",
  "required": ["selectors"],
  "properties": {
    "selectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["original", "healed", "confidence", "strategy"],
        "properties": {
          "original": { "type": "string" },
          "healed": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "strategy": {
            "type": "string",
            "enum": ["data_testid", "role", "text", "placeholder", "label", "css", "xpath"]
          },
          "testName": { "type": "string" },
          "testFile": { "type": "string" },
          "pageUrl": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
