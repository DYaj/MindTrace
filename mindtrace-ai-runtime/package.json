{
  "name": "@mindtrace/ai-runtime",
  "version": "1.0.0",
  "description": "MindTrace AI Runtime - Execution intelligence layer for Playwright (healing, RCA, governance, artifacts).",
  "license": "MIT",
  "author": "MindTrace Inc.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DYaj/mindtrace-for-playwright.git"
  },
  "bugs": {
    "url": "https://github.com/DYaj/mindtrace-for-playwright/issues"
  },
  "homepage": "https://github.com/DYaj/mindtrace-for-playwright#readme",
  "keywords": [
    "mindtrace",
    "playwright",
    "testing",
    "automation",
    "mcp",
    "self-healing",
    "rca",
    "observability",
    "ci",
    "teamcity"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "bin": {
    "mindtrace": "./dist/cli.js",
    "mindtrace-mcp": "./dist/mcp/cli.js"
  },
  "files": [
    "dist",
    "contracts",
    "README.md",
    "LICENSE",
    "prompts",
    "scripts"
  ],
  "scripts": {
    "prebuild": "bash scripts/prebuild-sync-contracts.sh && bash scripts/prebuild-sync-prompts.sh",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"const fs=require('fs'); try{fs.chmodSync('dist/cli.js',0o755);}catch(e){} try{fs.chmodSync('dist/mcp/cli.js',0o755);}catch(e){}\"",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "smoke:packaged": "node scripts/smoke-packaged.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.49.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.2.0",
    "openai": "^4.67.3",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "private"
  }
}
