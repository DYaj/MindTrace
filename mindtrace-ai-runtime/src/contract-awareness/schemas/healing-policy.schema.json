{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindtrace.ai/schemas/healing-policy.schema.json",
  "title": "Healing Policy",
  "description": "Self-healing strategy and behavior configuration",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this contract file"
    },
    "mode": {
      "type": "string",
      "description": "Healing mode (e.g., deterministic, adaptive)"
    },
    "retryStrategy": {
      "type": "string",
      "description": "Retry strategy for failed selectors"
    }
  },
  "additionalProperties": true
}
