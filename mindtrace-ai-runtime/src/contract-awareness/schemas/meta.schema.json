{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindtrace.ai/schemas/meta.schema.json",
  "title": "Contract Metadata",
  "description": "Metadata about contract generation and provenance",
  "type": "object",
  "required": ["schema_version", "generated_by"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this contract file"
    },
    "generated_by": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool name that generated the contract"
        },
        "version": {
          "type": "string",
          "description": "Tool version"
        }
      },
      "description": "Generator tool information"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    }
  },
  "additionalProperties": true
}
